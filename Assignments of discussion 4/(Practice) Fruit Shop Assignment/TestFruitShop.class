package com.axsos.assignments.D4;

import org.testng.Assert;

import org.testng.annotations.BeforeClass; 

import org.testng.annotations.Test;

import org.testng.annotations.AfterMethod;
import org.testng.annotations.AfterSuite;
import org.testng.annotations.BeforeMethod;
import org.testng.annotations.BeforeSuite;



public class TestFruitShop{
	
	
	

	private FruitShopitem Fruit = new FruitShopitem();
	
	@BeforeSuite
	public void sayWelcome (){ 
		System.out.println("Welcome to the fruit shop "); 
		}
	
	@BeforeClass
	public void createFruits (){ 
		//add items to 
		Fruit.addFruit("Orange");
		Fruit.addFruit("Banana");
		Fruit.addFruit("Apple");
		Fruit.addFruit("Strawberry");
		 System.out.println("Successful created items"); 
		 // to check content of array
		 System.out.println("Defualt fruits available in store: " + Fruit.getFruit());
		 System.out.println("---------------------------------");
		 
	}
	
//////////////////////////////////The cart should contain 4 items. (priority 1)///////////////////////
	@BeforeMethod
	public void beforeMthod (){
		System.out.println("Method start now");
		
		}
	
	
	@Test (priority =1)
	public void cartHaveFourItems (){
		int  itemsInCart = 4;
		System.out.println("Fruits available in store : " + Fruit.getFruit() + " as 4 items");
		Assert . assertEquals ( Fruit.length() , itemsInCart , "The cart doesn't have 4 items " ) ;
	
	}
	
	
	
	///////////////////////////////////The second item of the cart should be "Banana". (priority 3)/////////////////
	
	
	@Test (priority =3)
	public void findBanana (){
		String  expectedResult = "Banana";
		System.out.println("Banana in fruits is available in store : " + Fruit.get(1));
		Assert . assertEquals ( Fruit.get(1) , expectedResult , "The second item is not Banana " ) ;
		
	} 
	
	/////////////////////////////////The items in the cart should not contain Pineapple. (priority 2)//////////////////
		  
	@Test(priority =2)
	public void noPineapple (){ //AssertNotEquals 

		System.out.println("Fruits available in store and no Pineapple : " + Fruit.getFruit());
		String  expectedResult = "Pineapple";
		Assert . assertNotEquals ( Fruit.contains(expectedResult) ,  "Your shop scammed you, you have Pineapple " ) ;
		
		
	} 
	
	
/////////////////////////////////Number of items should become 5 after adding Mango to the cart. (priority 4)///////////////
	
	@Test(priority =4)
	public void addMango (){ 
		Fruit.addFruit("Mango");
		//System.out.println("Fruits available in store after add mango: " + Fruit.getFruit());
	}
	
	
	@Test(priority =5)
	public void itemsInCartIsFive (){ //AssertNotEquals 
		
		int  itemsInCart = 5;
		System.out.println("Fruits available in store is 5 and they are: " + Fruit.getFruit());
		Assert . assertEquals ( Fruit.length() , itemsInCart , "The cart doesn't have 5 items " ) ;
		
	} 
	
	@AfterMethod
	public void afterMehtod (){ 
		System.out.println("Method is done");
		System.out.println("*******************"); 
		}
	
	@AfterSuite
	public void sayGoodBye (){ 
		System.out.println("Goodbye and see you later "); 
		}
	
	  
}
